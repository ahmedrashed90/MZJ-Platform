DATABASE_URL=
MZJ_SETUP_KEY=
MZJ_GATEWAY_SECRET=
AUTOMATION_SCHEDULER_URL=
AUTOMATION_SCHEDULER_SECRET=

# Private Cloudflare R2 storage for CRM images, voice notes, video and documents.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=

# Stable public origin used to store authenticated platform media resolver URLs.
# Example: https://mzj-platform.vercel.app
MZJ_PUBLIC_BASE_URL=

# WhatsApp / Mersal token stays inside Cloudflare Worker, never in Vercel.
# Sending and template synchronization routes are read from CRM > Endpoints / Workers.
