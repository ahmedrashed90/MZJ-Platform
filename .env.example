DATABASE_URL=
MZJ_SETUP_KEY=
MZJ_GATEWAY_SECRET=
AUTOMATION_SCHEDULER_URL=
AUTOMATION_SCHEDULER_SECRET=

# Private Cloudflare R2 storage for CRM images, voice notes, video and documents.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=

# WhatsApp / Mersal token stays inside Cloudflare Worker, never in Vercel.
# Sending and template synchronization routes are read from CRM > Endpoints / Workers.

# Tracking orders integration from Google Apps Script. Optional; when set, send it as x-mzj-tracking-key.
TRACKING_INGEST_KEY=

# Direct ERPNext Sales Order webhook. Send the same value in the X-MZJ-ERPNext-Key header.
# If left empty, the endpoint falls back to TRACKING_INGEST_KEY.
ERPNEXT_WEBHOOK_KEY=
TRACKING_PUBLIC_BASE_URL=https://mzj-platform.vercel.app

# Firebase is used only for SMS+ queue documents in sms_outbox.
FIREBASE_PROJECT_ID=mzj-tracking
FIREBASE_API_KEY=
# Recommended secure server-side credentials (choose JSON or the two split variables).
FIREBASE_SERVICE_ACCOUNT_JSON=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Marketing native module. Never expose these values to the browser.
MARKETING_TOKEN_ENCRYPTION_KEY=
MARKETING_PUBLIC_BASE_URL=https://mzj-platform.vercel.app
MARKETING_AUTO_PUBLISH_ENABLED=false
TIKTOK_MARKETING_OAUTH_ENABLED=false
TIKTOK_MARKETING_CLIENT_KEY=
TIKTOK_MARKETING_CLIENT_SECRET=
SNAPCHAT_MARKETING_OAUTH_ENABLED=false
SNAPCHAT_MARKETING_CLIENT_ID=
SNAPCHAT_MARKETING_CLIENT_SECRET=
MERSAL_MARKETING_ENDPOINT=
MERSAL_MARKETING_TOKEN=

# Local publisher agent values belong on each paired device, not Vercel.
# MZJ_MARKETING_API_BASE=https://mzj-platform.vercel.app
# MZJ_MARKETING_DEVICE_TOKEN=
# MZJ_AGENDA_FOLDER=
