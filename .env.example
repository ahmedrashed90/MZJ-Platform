DATABASE_URL=
MZJ_SETUP_KEY=
MZJ_GATEWAY_SECRET=
AUTOMATION_SCHEDULER_URL=
AUTOMATION_SCHEDULER_SECRET=

# Private Cloudflare R2 storage for CRM images, voice notes, video and documents.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=

# WhatsApp / Mersal token stays inside Cloudflare Worker, never in Vercel.
# Optional Worker URL overrides. Normal routing is read from CRM > Endpoints / Workers.
MERSAL_WORKER_URL=
MERSAL_WORKER_TEMPLATES_URL=

# Cloudflare Worker forwards incoming WhatsApp events to the current PostgreSQL platform.
# Set these in the mersal-crm Worker, not in the browser build:
# MZJ_PLATFORM_INBOUND_URL=https://mzj-platform.vercel.app/api/integrations/whatsapp
# MZJ_GATEWAY_SECRET=<same value configured in Vercel>
