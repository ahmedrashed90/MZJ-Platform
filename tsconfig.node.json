{
  "compilerOptions": {
    "composite": true,
    "skipLibCheck": true,
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "noEmit": true,
    "types": [
      "node"
    ]
  },
  "include": [
    "vite.config.ts",
    "api/**/*.ts",
    "server/**/*.ts",
    "src/types.ts",
    "shared/**/*.ts"
  ]
}
